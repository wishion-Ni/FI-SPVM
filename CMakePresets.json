{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "FI_SPVM_ENABLE_OPENMP": "ON",
        "FI_SPVM_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "dev-windows-base",
      "hidden": true,
      "inherits": "dev-base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "dev-windows",
      "displayName": "Dev Windows (Auto Generator)",
      "inherits": "dev-windows-base"
    },
    {
      "name": "dev-windows-vs2022",
      "displayName": "Dev Windows (VS 2022)",
      "inherits": "dev-windows-base",
      "generator": "Visual Studio 17 2022"
    },
    {
      "name": "dev-windows-vs2019",
      "displayName": "Dev Windows (VS 2019)",
      "inherits": "dev-windows-base",
      "generator": "Visual Studio 16 2019"
    },
    {
      "name": "dev-windows-ninja",
      "displayName": "Dev Windows (Ninja)",
      "inherits": "dev-windows-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "dev-linux",
      "displayName": "Dev Linux",
      "inherits": "dev-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-dev-windows",
      "configurePreset": "dev-windows",
      "configuration": "Release"
    },
    {
      "name": "build-dev-windows-vs2022",
      "configurePreset": "dev-windows-vs2022",
      "configuration": "Release"
    },
    {
      "name": "build-dev-windows-vs2019",
      "configurePreset": "dev-windows-vs2019",
      "configuration": "Release"
    },
    {
      "name": "build-dev-windows-ninja",
      "configurePreset": "dev-windows-ninja"
    },
    {
      "name": "build-dev-linux",
      "configurePreset": "dev-linux"
    }
  ],
  "testPresets": [
    {
      "name": "test-dev-windows",
      "configurePreset": "dev-windows",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-dev-windows-vs2022",
      "configurePreset": "dev-windows-vs2022",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-dev-windows-vs2019",
      "configurePreset": "dev-windows-vs2019",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-dev-windows-ninja",
      "configurePreset": "dev-windows-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-dev-linux",
      "configurePreset": "dev-linux",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
