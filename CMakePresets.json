{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "toolchainFile": "${sourceDir}/cmake/vcpkg-toolchain.cmake",
      "cacheVariables": {
        "FI_SPVM_ENABLE_OPENMP": "ON",
        "FI_SPVM_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "dev-windows-base",
      "hidden": true,
      "inherits": "dev-base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "dev-windows",
      "displayName": "Dev Windows (Auto Generator)",
      "inherits": "dev-windows-base"
    },
    {
      "name": "dev-windows-vs2022",
      "displayName": "Dev Windows (VS 2022)",
      "inherits": "dev-windows-base",
      "generator": "Visual Studio 17 2022"
    },
    {
      "name": "dev-windows-vs2019",
      "displayName": "Dev Windows (VS 2019)",
      "inherits": "dev-windows-base",
      "generator": "Visual Studio 16 2019"
    },
    {
      "name": "dev-windows-ninja",
      "displayName": "Dev Windows (Ninja)",
      "inherits": "dev-windows-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "dev-windows-no-openmp",
      "displayName": "Dev Windows (No OpenMP)",
      "inherits": "dev-windows-base",
      "cacheVariables": {
        "FI_SPVM_ENABLE_OPENMP": "OFF"
      }
    },
    {
      "name": "dev-linux",
      "displayName": "Dev Linux",
      "inherits": "dev-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "dev-linux-no-openmp",
      "displayName": "Dev Linux (No OpenMP)",
      "inherits": "dev-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "FI_SPVM_ENABLE_OPENMP": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-dev-windows",
      "configurePreset": "dev-windows",
      "configuration": "Release"
    },
    {
      "name": "build-dev-windows-vs2022",
      "configurePreset": "dev-windows-vs2022",
      "configuration": "Release"
    },
    {
      "name": "build-dev-windows-vs2019",
      "configurePreset": "dev-windows-vs2019",
      "configuration": "Release"
    },
    {
      "name": "build-dev-windows-ninja",
      "configurePreset": "dev-windows-ninja"
    },
    {
      "name": "build-dev-windows-no-openmp",
      "configurePreset": "dev-windows-no-openmp",
      "configuration": "Release"
    },
    {
      "name": "build-dev-linux",
      "configurePreset": "dev-linux"
    },
    {
      "name": "build-dev-linux-no-openmp",
      "configurePreset": "dev-linux-no-openmp"
    }
  ],
  "testPresets": [
    {
      "name": "test-dev-windows",
      "configurePreset": "dev-windows",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-dev-windows-vs2022",
      "configurePreset": "dev-windows-vs2022",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-dev-windows-vs2019",
      "configurePreset": "dev-windows-vs2019",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-dev-windows-ninja",
      "configurePreset": "dev-windows-ninja",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-dev-windows-no-openmp",
      "configurePreset": "dev-windows-no-openmp",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-dev-linux",
      "configurePreset": "dev-linux",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-dev-linux-no-openmp",
      "configurePreset": "dev-linux-no-openmp",
      "output": {
        "outputOnFailure": true
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "workflow-dev-windows",
      "steps": [
        {
          "type": "configure",
          "name": "dev-windows"
        },
        {
          "type": "build",
          "name": "build-dev-windows"
        },
        {
          "type": "test",
          "name": "test-dev-windows"
        }
      ]
    },
    {
      "name": "workflow-dev-windows-vs2022",
      "steps": [
        {
          "type": "configure",
          "name": "dev-windows-vs2022"
        },
        {
          "type": "build",
          "name": "build-dev-windows-vs2022"
        },
        {
          "type": "test",
          "name": "test-dev-windows-vs2022"
        }
      ]
    },
    {
      "name": "workflow-dev-windows-vs2019",
      "steps": [
        {
          "type": "configure",
          "name": "dev-windows-vs2019"
        },
        {
          "type": "build",
          "name": "build-dev-windows-vs2019"
        },
        {
          "type": "test",
          "name": "test-dev-windows-vs2019"
        }
      ]
    },
    {
      "name": "workflow-dev-windows-ninja",
      "steps": [
        {
          "type": "configure",
          "name": "dev-windows-ninja"
        },
        {
          "type": "build",
          "name": "build-dev-windows-ninja"
        },
        {
          "type": "test",
          "name": "test-dev-windows-ninja"
        }
      ]
    },
    {
      "name": "workflow-dev-windows-no-openmp",
      "steps": [
        {
          "type": "configure",
          "name": "dev-windows-no-openmp"
        },
        {
          "type": "build",
          "name": "build-dev-windows-no-openmp"
        },
        {
          "type": "test",
          "name": "test-dev-windows-no-openmp"
        }
      ]
    },
    {
      "name": "workflow-dev-linux",
      "steps": [
        {
          "type": "configure",
          "name": "dev-linux"
        },
        {
          "type": "build",
          "name": "build-dev-linux"
        },
        {
          "type": "test",
          "name": "test-dev-linux"
        }
      ]
    },
    {
      "name": "workflow-dev-linux-no-openmp",
      "steps": [
        {
          "type": "configure",
          "name": "dev-linux-no-openmp"
        },
        {
          "type": "build",
          "name": "build-dev-linux-no-openmp"
        },
        {
          "type": "test",
          "name": "test-dev-linux-no-openmp"
        }
      ]
    }
  ]
}
